generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  phone            String?
  password         String?
  role             UserRole         @default(CUSTOMER)
  emailVerified    DateTime?
  image            String?
  resetToken       String?          @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  accounts         Account[]
  addresses        Address[]
  cart             CartItem[]
  giftOrders       GiftOrder[]
  inStoreSales     InStoreSale[]
  orders           Order[]
  paymentRequests  PaymentRequest[]
  reviews          Review[]
  sessions         Session[]
  stockHistory     StockHistory[]
  wishlist         WishlistItem[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String
  price          Float
  compareAtPrice Float?
  images         String[]
  categoryId     String
  stock          Int              @default(0)
  sku            String           @unique
  featured       Boolean          @default(false)
  fragranceType  FragranceType?
  topNotes       String[]
  heartNotes     String[]
  baseNotes      String[]
  longevity      Longevity?
  strength       Strength?
  moodTags       String[]
  gender         Gender?
  averageRating  Float?
  reviewCount    Int              @default(0)
  deleted        Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  cartItems      CartItem[]
  giftOrderItems GiftOrderItem[]
  orderItems     OrderItem[]
  popupConfigs   PopupConfig[]
  category       Category         @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  reviews        Review[]
  stockHistory   StockHistory[]
  wishlistItems  WishlistItem[]

  @@index([categoryId])
  @@index([slug])
  @@index([featured])
}

model ProductVariant {
  id             String          @id @default(cuid())
  productId      String
  name           String
  sku            String          @unique
  price          Float
  compareAtPrice Float?
  stock          Int             @default(0)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  cartItems      CartItem[]
  giftOrderItems GiftOrderItem[]
  orderItems     OrderItem[]
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockHistory   StockHistory[]
  wishlistItems  WishlistItem[]

  @@index([productId])
  @@index([sku])
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique
  userId           String?
  guestEmail       String?
  guestName        String?
  subtotal         Float
  discount         Float         @default(0)
  shippingCost     Float         @default(0)
  total            Float
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(PENDING)
  paymentMethod    String
  paymentReference String?
  shippingAddress  Json
  couponCode       String?
  couponId         String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  shippedAt        DateTime?
  deliveredAt      DateTime?
  coupon           Coupon?       @relation(fields: [couponId], references: [id])
  user             User?         @relation(fields: [userId], references: [id])
  items            OrderItem[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  variantName String?
  quantity    Int
  price       Float
  subtotal    Float
  createdAt   DateTime        @default(now())
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Review {
  id               String       @id @default(cuid())
  productId        String
  userId           String
  rating           Int
  title            String?
  comment          String
  verifiedPurchase Boolean      @default(false)
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([status])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  minOrderValue Float?
  maxUsageCount Int?
  usageCount    Int          @default(0)
  expiresAt     DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  orders        Order[]

  @@index([code])
  @@index([active])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  name       String
  phone      String
  address    String
  city       String
  state      String?
  postalCode String
  country    String   @default("Nigeria")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WishlistItem {
  id        String          @id @default(cuid())
  userId    String
  productId String
  variantId String?
  createdAt DateTime        @default(now())
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([userId])
  @@index([productId])
  @@index([variantId])
}

model CartItem {
  id        String          @id @default(cuid())
  userId    String
  productId String
  variantId String?
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([userId])
  @@index([productId])
  @@index([variantId])
}

model StockHistory {
  id            String          @id @default(cuid())
  productId     String
  variantId     String?
  userId        String?
  inStoreSaleId String?
  previousStock Int
  newStock      Int
  change        Int
  channel       StockChannel    @default(MANUAL_ADJUSTMENT)
  /// Legacy free-text reason kept for backward compatibility; prefer channel enum
  reason        String
  notes         String?
  createdAt     DateTime        @default(now())
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          User?           @relation(fields: [userId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  inStoreSale   InStoreSale?    @relation(fields: [inStoreSaleId], references: [id])

  @@index([productId])
  @@index([variantId])
  @@index([userId])
  @@index([channel])
  @@index([createdAt])
}

model InStoreSale {
  id            String              @id @default(cuid())
  saleNumber    String              @unique
  staffId       String?
  customerName  String?
  items         Json
  subtotal      Float
  total         Float
  paymentMethod InStorePayment      @default(CASH)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  staff         User?               @relation(fields: [staffId], references: [id])
  stockHistory  StockHistory[]

  @@index([staffId])
  @@index([createdAt])
}

model ShippingRate {
  id        String   @id @default(cuid())
  state     String   @unique
  fee       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
}

model GiftBoxSizeTier {
  id          String      @id @default(cuid())
  key         GiftBoxSizeKey @unique
  label       String
  itemRange   String
  maxItems    Int
  price       Float
  description String
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([active])
  @@index([sortOrder])
}

model GiftBox {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String
  image       String
  theme       GiftBoxTheme
  active      Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  giftOrders  GiftOrder[]

  @@index([theme])
  @@index([active])
}

model GiftCustomization {
  id           String           @id @default(cuid())
  message      String?          @db.VarChar(200)
  cardStyle    GiftCardStyle    @default(MINIMAL)
  ribbonStyle  GiftRibbonStyle  @default(SATIN)
  ribbonColor  GiftRibbonColor  @default(BLACK)
  boxSize      GiftBoxSizeKey   @default(SMALL)
  deliveryDate DateTime?
  anonymous    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  giftOrder    GiftOrder?
}

model GiftOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  userId           String?
  guestEmail       String?
  guestName        String?
  giftBoxId        String
  customizationId  String            @unique
  subtotal         Float
  boxPrice         Float
  total            Float
  shippingAddress  Json
  status           GiftOrderStatus   @default(DRAFT)
  paymentStatus    PaymentStatus     @default(PENDING)
  paymentMethod    String?
  paymentReference String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customization    GiftCustomization @relation(fields: [customizationId], references: [id])
  giftBox          GiftBox           @relation(fields: [giftBoxId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  items            GiftOrderItem[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model GiftOrderItem {
  id          String          @id @default(cuid())
  giftOrderId String
  productId   String
  variantId   String?
  variantName String?
  quantity    Int             @default(1)
  price       Float
  createdAt   DateTime        @default(now())
  giftOrder   GiftOrder       @relation(fields: [giftOrderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([giftOrderId])
  @@index([productId])
  @@index([variantId])
}

model PaymentRequest {
  id               String               @id @default(cuid())
  /// 32-byte cryptographically random hex token used in the shareable URL
  token            String               @unique
  /// Who created the request (authenticated users)
  userId           String?
  /// Contact info for the requester (always captured, even for auth'd users)
  requesterEmail   String
  requesterName    String?
  /// Snapshot of the order at request-creation time
  items            Json
  shippingAddress  Json
  subtotal         Float
  discount         Float                @default(0)
  shippingCost     Float                @default(0)
  total            Float
  couponCode       String?
  couponId         String?
  status           PaymentRequestStatus @default(PENDING)
  expiresAt        DateTime
  /// Filled in after the payer completes payment
  paymentReference String?
  payerEmail       String?
  orderId          String?
  paidAt           DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User?                @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ChatLog {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String?
  userMessage String
  botReply    String
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

model PopupConfig {
  id              String    @id @default(cuid())
  enabled         Boolean   @default(false)
  title           String    @default("")
  description     String    @default("")
  ctaLabel        String    @default("Shop Now")
  ctaUrl          String    @default("/shop")
  imageUrl        String?
  productName     String?
  originalPrice   Float?
  discountPercent Float?
  delaySeconds    Int       @default(4)
  startDate       DateTime?
  endDate         DateTime?
  productId       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  product         Product?  @relation(fields: [productId], references: [id])

  @@index([productId])
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum StockChannel {
  ONLINE_ORDER
  IN_STORE_SALE
  MANUAL_ADJUSTMENT
  RESTOCK
  CANCELLATION
  REFUND
}

enum InStorePayment {
  CASH
  POS
  TRANSFER
}

enum FragranceType {
  FLORAL
  WOODY
  CITRUS
  ORIENTAL
  FRESH
  FRUITY
  EARTHY
  GOURMAND
}

enum Longevity {
  SHORT
  MODERATE
  LONG
  VERY_LONG
}

enum Strength {
  LIGHT
  MODERATE
  STRONG
  VERY_STRONG
}

enum Gender {
  UNISEX
  MALE
  FEMALE
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum GiftBoxSizeKey {
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}

enum GiftBoxTheme {
  SIGNATURE_CREAM
  NOIR_LUXURY
  ROMANTIC_BLUSH
}

enum GiftCardStyle {
  MINIMAL
  ROMANTIC
  BIRTHDAY
  LUXURY_GOLD
}

enum GiftRibbonStyle {
  SATIN
  GROSGRAIN
  VELVET
}

enum GiftRibbonColor {
  BLACK
  GOLD
  ROSE_PINK
}

enum GiftOrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentRequestStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}
