// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
enum UserRole {
  CUSTOMER
  ADMIN
}

enum FragranceType {
  PERFUME
  EAU_DE_PARFUM
  EAU_DE_TOILETTE
  COLOGNE
  BODY_MIST
}

enum Longevity {
  SHORT        // 1-3 hours
  MODERATE     // 3-6 hours
  LONG         // 6-12 hours
  VERY_LONG    // 12+ hours
}

enum Strength {
  LIGHT
  MODERATE
  STRONG
  VERY_STRONG
}

enum Gender {
  UNISEX
  MALE
  FEMALE
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  password      String?   // hashed, optional for OAuth users
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  
  // Password reset fields
  resetToken    String?   @unique
  resetTokenExpiry DateTime?
  
  orders           Order[]
  reviews          Review[]
  wishlist         WishlistItem[]
  addresses        Address[]
  cart             CartItem[]
  accounts         Account[]
  sessions         Session[]
  stockHistory     StockHistory[]
  giftOrders       GiftOrder[]
  paymentRequests  PaymentRequest[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String
  // Base price / stock / sku kept for products with no variants.
  // When variants exist these fields reflect the lowest variant price
  // and are managed automatically — do not edit directly.
  price           Float
  compareAtPrice  Float?
  images          String[]
  categoryId      String
  category        Category        @relation(fields: [categoryId], references: [id])
  stock           Int             @default(0)
  sku             String          @unique
  featured        Boolean         @default(false)
  
  // Fragrance-specific fields
  fragranceType   FragranceType?
  topNotes        String[]
  heartNotes      String[]
  baseNotes       String[]
  longevity       Longevity?
  strength        Strength?
  moodTags        String[]
  gender          Gender?
  
  reviews         Review[]
  averageRating   Float?
  reviewCount     Int             @default(0)
  
  variants        ProductVariant[]
  orderItems      OrderItem[]
  wishlistItems   WishlistItem[]
  cartItems       CartItem[]
  stockHistory    StockHistory[]
  giftOrderItems  GiftOrderItem[]
  popupConfigs    PopupConfig[]
  
  deleted         Boolean         @default(false)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([categoryId])
  @@index([slug])
  @@index([featured])
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name           String   // e.g. "50ml", "250g", "100ml / Black"
  sku            String   @unique
  price          Float
  compareAtPrice Float?
  stock          Int      @default(0)
  sortOrder      Int      @default(0)

  cartItems      CartItem[]
  orderItems     OrderItem[]
  wishlistItems  WishlistItem[]
  stockHistory   StockHistory[]
  giftOrderItems GiftOrderItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  
  // Guest checkout support
  guestEmail      String?
  guestName       String?
  
  items           OrderItem[]
  subtotal        Float
  discount        Float         @default(0)
  shippingCost    Float         @default(0)
  total           Float
  
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   String
  paymentReference String?
  
  shippingAddress Json          // Store address as JSON
  
  couponCode      String?
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  variantName String?         // snapshot of variant name at time of purchase
  quantity    Int
  price       Float           // Price at time of purchase
  subtotal    Float
  
  createdAt   DateTime @default(now())
  
  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Review {
  id                String       @id @default(cuid())
  productId         String
  product           Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId            String
  user              User         @relation(fields: [userId], references: [id])
  rating            Int          // 1-5
  title             String?
  comment           String
  verifiedPurchase  Boolean      @default(false)
  status            ReviewStatus @default(PENDING)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([productId])
  @@index([userId])
  @@index([status])
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  discountType    DiscountType
  discountValue   Float
  minOrderValue   Float?
  maxUsageCount   Int?
  usageCount      Int          @default(0)
  expiresAt       DateTime?
  active          Boolean      @default(true)
  
  orders          Order[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([code])
  @@index([active])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  phone       String
  address     String
  city        String
  state       String?
  postalCode  String
  country     String   @default("Nigeria")
  isDefault   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
}

model WishlistItem {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, productId, variantId])
  @@index([userId])
  @@index([productId])
  @@index([variantId])
}

model CartItem {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity    Int             @default(1)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, productId, variantId])
  @@index([userId])
  @@index([productId])
  @@index([variantId])
}

model StockHistory {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  previousStock Int
  newStock      Int
  change        Int
  reason        String   // e.g., "Manual adjustment", "Order completed", "Order cancelled"
  notes         String?
  
  createdAt   DateTime @default(now())
  
  @@index([productId])
  @@index([variantId])
  @@index([userId])
  @@index([createdAt])
}

// ── Gift Box Feature ───────────────────────────────────────────────────────

enum GiftBoxTheme {
  SIGNATURE_CREAM   // cream textured, black satin ribbon, gold embossed
  NOIR_LUXURY       // matte black rigid, velvet interior, gold foil
  ROMANTIC_BLUSH    // nude/blush tones, silk ribbon, floral insert
}

enum GiftCardStyle {
  MINIMAL
  ROMANTIC
  BIRTHDAY
  LUXURY_GOLD
}

enum GiftRibbonStyle {
  BLACK_SATIN
  IVORY_SILK
  BLUSH_RIBBON
  GOLD_VELVET
}

enum GiftOrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ── Shipping Rates ─────────────────────────────────────────────────────────

model ShippingRate {
  id        String   @id @default(cuid())
  state     String   @unique  // Nigerian state name, e.g. "Lagos"
  fee       Float             // Shipping fee in Naira
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
}

model GiftBox {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  description String
  image       String
  maxItems    Int
  price       Float        // base box price
  theme       GiftBoxTheme
  active      Boolean      @default(true)
  sortOrder   Int          @default(0)

  giftOrders  GiftOrder[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([theme])
  @@index([active])
}

model GiftCustomization {
  id           String          @id @default(cuid())
  message      String?         @db.VarChar(200)
  cardStyle    GiftCardStyle   @default(MINIMAL)
  ribbonStyle  GiftRibbonStyle @default(BLACK_SATIN)
  deliveryDate DateTime?
  anonymous    Boolean         @default(false)

  giftOrder    GiftOrder?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model GiftOrder {
  id               String          @id @default(cuid())
  orderNumber      String          @unique
  userId           String?
  user             User?           @relation(fields: [userId], references: [id])

  // Guest support
  guestEmail       String?
  guestName        String?

  giftBoxId        String
  giftBox          GiftBox         @relation(fields: [giftBoxId], references: [id])

  customizationId  String          @unique
  customization    GiftCustomization @relation(fields: [customizationId], references: [id])

  items            GiftOrderItem[]

  subtotal         Float
  boxPrice         Float
  total            Float

  shippingAddress  Json

  status           GiftOrderStatus @default(DRAFT)
  paymentStatus    PaymentStatus   @default(PENDING)
  paymentMethod    String?
  paymentReference String?

  notes            String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model GiftOrderItem {
  id           String          @id @default(cuid())
  giftOrderId  String
  giftOrder    GiftOrder       @relation(fields: [giftOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  variantName  String?
  quantity     Int             @default(1)
  price        Float           // price at time of order

  createdAt    DateTime  @default(now())

  @@index([giftOrderId])
  @@index([productId])
  @@index([variantId])
}

// ── Pay-For-Me / Payment Request ──────────────────────────────────────────

enum PaymentRequestStatus {
  PENDING   // link is active, waiting for payment
  PAID      // payer completed payment, order created
  EXPIRED   // link passed its expiry time
  CANCELLED // requester cancelled the link
}

model PaymentRequest {
  id              String               @id @default(cuid())
  /// 32-byte cryptographically random hex token used in the shareable URL
  token           String               @unique

  /// Who created the request (authenticated users)
  userId          String?
  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Contact info for the requester (always captured, even for auth'd users)
  requesterEmail  String
  requesterName   String?

  /// Snapshot of the order at request-creation time
  items           Json                 // Array<{ productId, variantId, variantName, quantity, price, name, image }>
  shippingAddress Json                 // { name, phone, address, city, state, postalCode, country }
  subtotal        Float
  discount        Float                @default(0)
  shippingCost    Float                @default(0)
  total           Float
  couponCode      String?
  couponId        String?

  status          PaymentRequestStatus @default(PENDING)
  expiresAt       DateTime

  /// Filled in after the payer completes payment
  paymentReference String?
  payerEmail      String?
  orderId         String?              // the Order record created on payment

  paidAt          DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([token])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ── Promotional Popup ──────────────────────────────────────────────────────

model PopupConfig {
  id              String    @id @default(cuid())
  enabled         Boolean   @default(false)
  title           String    @default("")
  description     String    @default("")
  ctaLabel        String    @default("Shop Now")
  ctaUrl          String    @default("/shop")
  imageUrl        String?
  productName     String?
  originalPrice   Float?
  discountPercent Float?
  delaySeconds    Int       @default(4)
  startDate       DateTime?
  endDate         DateTime?

  // Optional link to an existing product
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([productId])
}
